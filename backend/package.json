{
  "name": "come-by-shop-backend",
  "version": "1.0.0",
  "description": "Come by Shop — backend API (Fastify + Drizzle + PostgreSQL)",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@t3-oss/env-core": "^0.10.1",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.1.0",
    "google-auth-library": "^9.14.1",
    "postgres": "^3.4.5",
    "resend": "^4.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.0",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.4",
    "typescript": "^5.7.2",
    "vitest": "^4.1.6"
  }
}
