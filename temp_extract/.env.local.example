# Скопіюй цей файл в .env.local і заповни значення
# cp .env.local.example .env.local

# URL бекенду (замість VITE_API_URL)
# Залиш порожнім — Next.js проксі /api на localhost:8080 через next.config.ts
NEXT_PUBLIC_API_URL=

# Google OAuth Client ID (замість VITE_GOOGLE_CLIENT_ID)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Публічна URL сайту (для sitemap та OG-тегів)
NEXT_PUBLIC_SITE_URL=https://come-by-shop.com
