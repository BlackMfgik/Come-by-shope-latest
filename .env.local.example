# ─── NextAuth ───────────────────────────────────────────────────────────────
# Генерується командою: openssl rand -base64 32
AUTH_SECRET=your_random_secret_here_min_32_chars

# Google OAuth — отримати на https://console.cloud.google.com
# Authorized redirect URI: https://comeby.ua/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# В продакшн — повна URL сайту
NEXTAUTH_URL=http://localhost:3000

# ─── TurboSMS (SMS OTP) ──────────────────────────────────────────────────────
TURBOSMS_TOKEN=your_turbosms_api_token
TURBOSMS_SENDER=ComeBySHOP

# ─── WayForPay ───────────────────────────────────────────────────────────────
WAYFORPAY_MERCHANT_ACCOUNT=your_merchant_login
WAYFORPAY_SECRET_KEY=your_secret_key_never_expose_to_frontend
WAYFORPAY_DOMAIN=comeby.ua
