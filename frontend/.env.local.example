# ─── Бекенд API ──────────────────────────────────────────────────────────────
# 🔌 URL вашого бекенду — всі /api/* запити йдуть сюди
# Локальна розробка: залишити порожнім (Next.js буде Next.js API Routes)
# Продакшн: https://api.come-by-shop.com або https://come-by-shop.com
NEXT_PUBLIC_API_URL=

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Генерується командою: openssl rand -base64 32
AUTH_SECRET=your_random_secret_here_min_32_chars

# URL сайту (для redirect URLs та NextAuth)
NEXT_PUBLIC_SITE_URL=https://come-by-shop.com
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Отримати на https://console.cloud.google.com
# Authorized redirect URI: https://comeby.ua/api/auth/callback/google
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── Cloudinary (завантаження зображень) ────────────────────────────────────
# Отримати на https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# ─── TurboSMS (SMS OTP для верифікації телефону) ────────────────────────────
# Отримати на https://turbosms.ua
# 🔌 Використовується: POST /api/auth/phone/send-otp
TURBOSMS_TOKEN=your_turbosms_api_token
TURBOSMS_SENDER=ComeBySHOP

# ─── WayForPay (платіжна система) ────────────────────────────────────────────
# Отримати на https://wayforpay.com
# 🔌 Використовується: POST /api/payment/wayforpay/init
# 🔌 Webhook: POST /api/payment/wayforpay/callback
WAYFORPAY_MERCHANT_ACCOUNT=your_merchant_login
WAYFORPAY_SECRET_KEY=your_secret_key_never_expose_to_frontend
WAYFORPAY_DOMAIN=come-by-shop.com

# ─── Email провайдер (для reset-password та change-email) ───────────────────
# 🔌 Використовується: POST /api/auth/reset-password
# 🔌 Використовується: POST /api/auth/change-email/request
# Варіанти: Resend (рекомендовано), SendGrid, Mailgun
EMAIL_PROVIDER_API_KEY=your_email_provider_api_key
EMAIL_FROM_ADDRESS=noreply@come-by-shop.com
